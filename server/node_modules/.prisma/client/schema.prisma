// prisma/schema.prisma
// This file defines the entire database schema for the Shopping Cart Application.
// Prisma uses this to generate the DB tables and the type-safe client.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  customer
  admin
}

enum AuthProvider {
  local
  google
  facebook
  passkey
}

enum OrderStatus {
  pending
  processing
  delivered
  cancelled
}

// ─────────────────────────────────────────────
// USERS
// Stores both customers (OAuth or local) and admins (local only).
// password_hash is nullable because OAuth users have no password.
// ─────────────────────────────────────────────

model User {
  id           String       @id @default(uuid())
  name         String
  email        String       @unique
  passwordHash String?      @map("password_hash")
  authProvider AuthProvider @default(local) @map("auth_provider")
  providerId   String?      @map("provider_id") // Google/Facebook sub/id
  role         Role         @default(customer)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  // Relations
  cart   Cart?
  orders Order[]

  @@map("users")
}

// ─────────────────────────────────────────────
// CATEGORIES
// Fixed: Vegetables, Fruits, Cakes, Biscuits
// Admin can rename but not add new ones in this version.
// ─────────────────────────────────────────────

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique // e.g., "vegetables" — used in URLs
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  products Product[]

  @@map("categories")
}

// ─────────────────────────────────────────────
// PRODUCTS
// Each product belongs to one category.
// Stock tracking is included.
// is_active allows soft-delete without losing order history.
// ─────────────────────────────────────────────

model Product {
  id          String   @id @default(uuid())
  categoryId  Int      @map("category_id")
  name        String
  description String   @db.Text
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  category   Category       @relation(fields: [categoryId], references: [id])
  images     ProductImage[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("products")
}

// ─────────────────────────────────────────────
// PRODUCT IMAGES
// A product can have multiple images.
// is_primary marks the thumbnail shown in listings.
// public_id is the Cloudinary ID needed for deletion.
// ─────────────────────────────────────────────

model ProductImage {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  imageUrl  String   @map("image_url")
  publicId  String   @map("public_id") // Cloudinary public_id
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

// ─────────────────────────────────────────────
// CARTS
// One cart per user (after login).
// Guest carts are identified by session_id stored in a cookie.
// user_id is nullable to support guest carts.
// ─────────────────────────────────────────────

model Cart {
  id        String   @id @default(uuid())
  userId    String?  @unique @map("user_id") // null = guest cart
  sessionId String?  @unique @map("session_id") // for guest identification
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

// ─────────────────────────────────────────────
// CART ITEMS
// Each row is one product in a cart with its quantity.
// ─────────────────────────────────────────────

model CartItem {
  id        String   @id @default(uuid())
  cartId    String   @map("cart_id")
  productId String   @map("product_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  // A product can only appear once per cart
  @@unique([cartId, productId])
  @@map("cart_items")
}

// ─────────────────────────────────────────────
// ORDERS
// Created at checkout. Stores delivery info and total.
// Items are snapshotted at time of purchase (unit_price stored).
// ─────────────────────────────────────────────

model Order {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  fullName    String      @map("full_name")
  address     String      @db.Text
  city        String
  phone       String
  totalAmount Decimal     @map("total_amount") @db.Decimal(10, 2)
  status      OrderStatus @default(pending)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relations
  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@map("orders")
}

// ─────────────────────────────────────────────
// ORDER ITEMS
// Snapshot of each product at order time.
// unit_price is stored separately so price changes don't affect old orders.
// ─────────────────────────────────────────────

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  productId String   @map("product_id")
  quantity  Int
  unitPrice Decimal  @map("unit_price") @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}
