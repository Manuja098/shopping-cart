{
  "version": 2,
  "buildCommand": "npx prisma generate",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["src/**", "node_modules/.prisma/**"] }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ]
}
